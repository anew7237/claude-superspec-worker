# ============================================================
# .env.example
# 複製成 .env 並填入實際值。.env 不會進 git。
# ============================================================

# Compose project name(影響 container 名稱前綴)
COMPOSE_PROJECT_NAME=mynodejs

# Port mapping(host 端 port,衝突時改這邊)
APP_PORT=8000
DB_PORT=5432
REDIS_PORT=6379

# Database
DB_PASSWORD=dev

# App
LOG_LEVEL=debug

# HTTP metrics middleware; set to 'false' to disable. Default: enabled
HTTP_METRICS_ENABLED=true

# ============================================================
# Dev container firewall(可選)
# 設成 1 啟用 init-firewall.sh,參見 .devcontainer/init-firewall.sh
# ============================================================
ENABLE_FIREWALL=0

# ============================================================
# Cross-platform
# 一般不用設,只有要強制某 platform 才需要
# 例:某個 base image 只有 amd64 → DOCKER_PLATFORM=linux/amd64
# ============================================================
# DOCKER_PLATFORM=linux/amd64
