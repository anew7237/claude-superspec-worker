{
  "name": "claude-superspec-worker",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0+sha512.4abf725084d7bcbafbd728bfc7bee61f2f791f977fd87542b3579dcb23504d170d46337945e4c66485cd12d588a0c0e570ed9c477e7ccdd8507cf05f3f92eaca",
  "scripts": {
    "dev": "node --watch --experimental-strip-types --disable-warning=ExperimentalWarning src/node/index.ts",
    "dev:node": "node --watch --experimental-strip-types --disable-warning=ExperimentalWarning src/node/index.ts",
    "dev:worker": "wrangler dev --config wrangler.jsonc",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/node/index.js",
    "test": "pnpm test:node && pnpm test:worker",
    "test:node": "vitest run --config vitest.config.node.ts",
    "test:worker": "vitest run --config vitest.config.worker.ts",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.worker.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "logs:worker": "wrangler tail",
    "db:migrate": "wrangler d1 migrations apply claude-superspec-worker --remote",
    "deploy:worker": "wrangler deploy --config wrangler.jsonc"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260503.1",
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.3.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.14.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0",
    "wrangler": "^4.0.0"
  }
}
